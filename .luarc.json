{
    "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
    "runtime.version": "Lua 5.1",
    "runtime.path": [
        "?.lua",
        "?/init.lua",
        "?/?.lua"
    ],
    "diagnostics.globals": [
        "BUIIDatabase",
        "BUIICharacterDatabase",
        "BUIIOptionsPanel",
        "buii",
        "describe",
        "it",
        "before_each",
        "after_each",
        "setup",
        "teardown",
        "spy",
        "mock",
        "match",
        "assert"
    ],
    "workspace.library": [
        "wow-ui-source",
        "vscode-wow-api/Annotations"
    ],
    "workspace.checkThirdParty": false,
    "diagnostics.disable": [
        "lowercase-global",
        "duplicate-set-field"
    ]
}
